{
  "name": "llm-docs-cli",
  "version": "0.2.0",
  "description": "Scrape JS-heavy documentation sites into clean LLM-friendly markdown",
  "type": "module",
  "license": "MIT",
  "files": [
    "bin",
    "src",
    "!src/__tests__"
  ],
  "bin": {
    "llm-docs": "./bin/llm-docs.mjs"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test-extract": "tsx scripts/test-extract.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm test && npm run typecheck"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "playwright-core": "^1.49.0",
    "tsx": "^4.19.0",
    "turndown": "^7.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/turndown": "^5.0.5",
    "typescript": "^5.6.0",
    "vitest": "^4.1.2"
  }
}
