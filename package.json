{
  "name": "llm-docs-cli",
  "version": "0.1.0",
  "description": "Scrape JS-heavy documentation sites into clean LLM-friendly markdown",
  "type": "module",
  "bin": {
    "llm-docs": "./bin/llm-docs.mjs"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npx tsc",
    "dev": "tsx src/cli.ts",
    "test-extract": "tsx src/test-extract.ts"
  },
  "dependencies": {
    "@mozilla/readability": "^0.5.0",
    "commander": "^14.0.3",
    "jsdom": "^25.0.1",
    "playwright": "^1.49.0",
    "turndown": "^7.2.0"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/turndown": "^5.0.5",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
